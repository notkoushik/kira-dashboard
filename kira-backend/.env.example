# ============================================
# KIRA Backend Configuration
# Copy this file to .env and fill in your values
# ============================================

# Node Environment
NODE_ENV=development
API_PORT=3000

# ============================================
# SUPABASE CONFIGURATION
# Get these from: https://app.supabase.com/projects
# ============================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ============================================
# JWT CONFIGURATION
# Use a strong random string for JWT_SECRET (min 32 characters)
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-at-least-32-characters
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# ============================================
# FRONTEND CONFIGURATION
# ============================================
FRONTEND_URL=http://localhost:5173

# ============================================
# REDIS CONFIGURATION (for background jobs)
# Optional: Leave as default for local development
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# EMAIL CONFIGURATION (Gmail with App Password)
# Get App Password: https://myaccount.google.com/apppasswords
# ============================================
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-gmail-app-password-here

# ============================================
# SENTRY CONFIGURATION (Error Tracking)
# Optional: Get from https://sentry.io
# ============================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ============================================
# APIFY CONFIGURATION (Job Scraping)
# Optional: Get token from https://apify.com
# ============================================
APIFY_API_TOKEN=
APIFY_ACTOR_ID=

# ============================================
# LOGGING
# Options: trace, debug, info, warn, error, fatal, silent
# ============================================
LOG_LEVEL=info
