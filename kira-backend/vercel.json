{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "API_PORT": "3000",
    "SUPABASE_URL": "@SUPABASE_URL",
    "SUPABASE_ANON_KEY": "@SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_KEY": "@SUPABASE_SERVICE_KEY",
    "JWT_SECRET": "@JWT_SECRET",
    "FRONTEND_URL": "@FRONTEND_URL"
  }
}

