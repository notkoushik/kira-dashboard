{
  "version": 2,
  "builds": [
    {
      "src": "kira-backend/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/kira-backend/src/index.ts"
    },
    {
      "src": "/index.html",
      "dest": "/index.html"
    },
    {
      "src": "^/(?!api).*",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}

